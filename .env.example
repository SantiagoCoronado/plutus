# Copy to .env and fill in. Never commit .env.
# One file serves both native dev (localhost hosts below) and Docker Compose
# (compose overrides DATABASE_URL/REDIS_URL hostnames per service).

# --- App ---
APP_AUTH_TOKEN=change-me-long-random         # static bearer token; every /api/v1 endpoint requires it; app refuses to boot if empty
BASE_CURRENCY=USD
TZ=America/Mexico_City
FRONTEND_ORIGIN=http://localhost:5173        # CORS allowlist (Vite dev server)

# --- Infra ---
POSTGRES_PASSWORD=plutus
DATABASE_URL=postgresql://plutus:plutus@localhost:5433/plutus   # compose maps db to host port 5433
REDIS_URL=redis://localhost:6379/0

# --- Data providers (selection is config, not code) ---
PROVIDER_STOCKS=tiingo                       # tiingo|finnhub|alphavantage (only tiingo implemented)
PROVIDER_CRYPTO=binance                      # binance (real OHLCV, keyless) | coingecko (synthetic candles); search/metadata always CoinGecko
PROVIDER_FOREX=twelvedata
PROVIDER_FUNDAMENTALS=fmp                    # fmp | edgar (keyless fallback, fewer fields)
PROVIDER_NEWS=finnhub

TIINGO_API_KEY=                              # https://www.tiingo.com — free tier: 50 req/hr, 1,000 req/day, 500 unique symbols/mo
COINGECKO_API_KEY=                           # optional demo key, https://www.coingecko.com/en/api — ~30 req/min, 10,000 req/mo; works keyless at lower limits
TWELVEDATA_API_KEY=                          # https://twelvedata.com — free tier: 8 credits/min, 800 credits/day
FINNHUB_API_KEY=                             # https://finnhub.io — free tier: 60 req/min; used for company news
FMP_API_KEY=                                 # https://financialmodelingprep.com — free tier: 250 req/day; stock fundamentals

# --- Benchmarks (relative strength per asset class) ---
BENCHMARK_STOCK=SPY
BENCHMARK_CRYPTO=BTC
BENCHMARK_FOREX=UUP                          # dollar-index ETF proxy; raw DXY needs a paid Twelve Data plan

# --- Ingestion ---
INITIAL_BACKFILL_DAYS=1825                   # ~5y: usable backtest window after the 300-bar indicator warmup

# Where quantstats HTML reports are written (compose overrides to /srv/artifacts)
ARTIFACTS_DIR=./artifacts

# --- Alerts (Phase 4, all optional) ---
# Email: set SMTP_HOST + ALERT_EMAIL_TO to enable. For Gmail use smtp.gmail.com:587
# with an app password (Google Account -> Security -> 2-Step Verification -> App passwords).
SMTP_HOST=
SMTP_PORT=587                                # 465 uses implicit TLS, anything else STARTTLS
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=                            # defaults to SMTP_USER

# Telegram: create a bot with @BotFather, message it once, then read your chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Portfolio (Phase 5) ---
MATURITY_REMINDER_DAYS=7                     # alert this many days before a bank investment matures

# --- AI agent layer (Phase 6) ---
LLM_PROVIDER=claude-subscription             # claude-subscription|anthropic-api|openai|google|openrouter|ollama
LLM_MODEL=                                   # provider-specific model id override (optional)
# claude-subscription: run `claude setup-token` and paste the result. Consumed ONLY by
# the agent-sidecar container — never set ANTHROPIC_API_KEY in the sidecar's env.
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_SIDECAR_URL=http://localhost:8787     # compose overrides to http://agent-sidecar:8787
ANTHROPIC_API_KEY=                           # only if LLM_PROVIDER=anthropic-api
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# encrypts API keys saved from the Settings UI; generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
AGENT_DAILY_TOKEN_BUDGET=500000              # hard cap; agent tasks stop when exceeded
AGENT_MAX_TOOL_ITERATIONS=15
AGENT_NIGHTLY_MEMO_LIMIT=3                   # research memos generated per night
MCP_TOOL_TIER=write                          # write = full agentic control; read = queries only
