# Copy to .env and fill in. Never commit .env.
# One file serves both native dev (localhost hosts below) and Docker Compose
# (compose overrides DATABASE_URL/REDIS_URL hostnames per service).

# --- App ---
APP_AUTH_TOKEN=change-me-long-random         # static bearer token; every /api/v1 endpoint requires it; app refuses to boot if empty
BASE_CURRENCY=USD
TZ=America/Mexico_City
FRONTEND_ORIGIN=http://localhost:5173        # CORS allowlist (Vite dev server)

# --- Infra ---
POSTGRES_PASSWORD=plutus
DATABASE_URL=postgresql://plutus:plutus@localhost:5433/plutus   # compose maps db to host port 5433
REDIS_URL=redis://localhost:6379/0

# --- Data providers (selection is config, not code) ---
PROVIDER_STOCKS=tiingo                       # tiingo|finnhub|alphavantage (only tiingo implemented in Phase 1)
PROVIDER_CRYPTO=coingecko
PROVIDER_FOREX=twelvedata

TIINGO_API_KEY=                              # https://www.tiingo.com — free tier: 50 req/hr, 1,000 req/day, 500 unique symbols/mo
COINGECKO_API_KEY=                           # optional demo key, https://www.coingecko.com/en/api — ~30 req/min, 10,000 req/mo; works keyless at lower limits
TWELVEDATA_API_KEY=                          # https://twelvedata.com — free tier: 8 credits/min, 800 credits/day
FINNHUB_API_KEY=                             # only needed if PROVIDER_STOCKS=finnhub (adapter lands post-Phase 1)

# --- Ingestion ---
INITIAL_BACKFILL_DAYS=730                    # first-ingest lookback; CoinGecko free tier clamps crypto to ~365 days
